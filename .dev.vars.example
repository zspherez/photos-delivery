# Local dev secrets — copy to .dev.vars (gitignored) and fill in real values.
# For production, set via: wrangler secret put <NAME>

NEXTJS_ENV=development

# Admin auth
ADMIN_PASSWORD=changeme
SESSION_SECRET=generate-a-long-random-string-here

# Resend (for invoice email delivery). INVOICE_FROM_EMAIL must be a verified sender.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
INVOICE_FROM_EMAIL=Your Name <invoices@yourdomain.com>

# Bank / payment info shown on generated invoice PDFs
BANK_ACCOUNT_NUMBER=
BANK_ROUTING_NUMBER=
BANK_NAME=
BANK_ACCOUNT_TYPE=Checking
VENMO_PHONE=

# R2 S3-compatible API credentials (R2 → Manage R2 API Tokens in dashboard)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_JURISDICTION_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
